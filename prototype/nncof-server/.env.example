# nncof-server 환경변수 예시 — 이 파일을 복사해서 .env 로 사용한다 (.env 는 .gitignore 대상).
#   cp .env.example .env
#
# 주의: APP_TITLE 이 비어 있으면 FastAPI 가
#   "A title must be provided for OpenAPI" 로 기동에 실패한다. 반드시 값이 있어야 한다.
APP_TITLE=Nncof_EventsSubscription
APP_DESCRIPTION=NCOF Event Exposure Service for 6G-I2P PoC Scenario.
APP_VERSION=0.1.0

# NCOF 가 알림(notification)을 보낼 때 사용하는 base URI
NCOF_NOTIFICATION_BASE_URI=http://localhost:8000/notifications

# gNB2 전력 결정 엔진: rule(기본) | rl
# NCOF_DECISION_ENGINE=rule
# NCOF_RL_POLICY_PATH=/path/to/gnb2_policy.json
